{
  "name": "aifas-backend",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "author": "NR Common Service Showcase <NR.CommonServiceShowcase@gov.bc.ca>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "build:all": "tsx ./deploy-utils.ts",
    "postbuild:all": "npm run build",
    "clean": "rimraf coverage dist sbin",
    "clean:all": "tsx ./deploy-utils.ts clean",
    "postclean:all": "npm run clean",
    "debug": "ts-node-dev --debug --respawn --transpile-only --rs --watch bin,config,dist ./bin/www",
    "format": "prettier ./src --write",
    "lint": "eslint . --no-fix",
    "prelint": "npm run typecheck",
    "pretest": "npm run lint",
    "posttest": "tsx ./lcov-fix.ts",
    "purge": "rimraf node_modules",
    "rebuild": "npm run clean && npm run build",
    "reinstall": "npm run purge && npm install",
    "serve": "tsx watch --include \"./config/*\" --include \"./dist/*\" ./server --clear-screen=false",
    "start": "tsx ./server",
    "test": "jest --verbose --forceExit --detectOpenHandles",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/compression": "^1.8.1",
    "@types/config": "^4.4.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.3",
    "api-problem": "^9.0.2",
    "axios": "^1.13.2",
    "compression": "^1.8.1",
    "config": "^4.4.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-winston": "^4.2.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "tsx": "^4.22.4",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
